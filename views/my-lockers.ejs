<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Partner Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-black: #111827;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --bg-main: #ffffff;
            --sidebar-width: 260px;
            --row-hover: #f8fafc;
        }

        body { 
            background-color: var(--bg-main); 
            font-family: 'Inter', sans-serif; 
            color: var(--brand-black);
            letter-spacing: -0.01em;
        }

        #main-wrapper { 
            margin-left: var(--sidebar-width); 
            padding: 40px 60px !important; 
        }

        /* Header Section */
        .page-header {
            margin-bottom: 32px;
        }

        /* Excel Table Container */
        .excel-wrapper {
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            background: white;
        }

        .table-excel {
            width: 100%;
            margin-bottom: 0;
            border-collapse: collapse;
        }

        .table-excel thead th {
            background: #f8fafc;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 700;
            padding: 14px 20px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
            text-align: left;
        }

        .table-excel tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: background 0.1s ease;
        }

        .table-excel tbody tr:last-child {
            border-bottom: none;
        }

        .table-excel tbody tr:hover {
            background-color: var(--row-hover);
        }

        .table-excel td {
            padding: 16px 20px;
            vertical-align: middle;
            font-size: 0.875rem;
        }

        /* Utilization Progress Bar */
        .mini-progress-container {
            width: 120px;
        }

        .progress {
            height: 6px;
            background-color: #f1f5f9;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-bar {
            background-color: var(--brand-black);
        }

        /* Status Pills */
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
        }

        .status-online { background-color: #10b981; }
        .status-offline { background-color: #ef4444; }

        /* Action Button */
        .btn-manage {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--brand-black);
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-manage:hover {
            background: var(--brand-black);
            color: white;
            border-color: var(--brand-black);
        }

        @media (max-width: 992px) { 
            #main-wrapper { margin-left: 0; padding: 40px 20px !important; } 
        }
    </style>
</head>
<body>
    <%- include("./imports/topbar") %>
    <%- include("./imports/sidebar") %>

    <div id="main-wrapper">
        <div class="page-header mt-5">
            <h2 class="fw-bold mb-1">My Locker Fleet</h2>
            <p class="text-muted small">Manage all hardware assets in a consolidated list view.</p>
        </div>

        <div class="excel-wrapper">
            <table class="table-excel">
                <thead>
                    <tr>
                        <th width="15%">Locker ID</th>
                        <th width="10%">Status</th>
                        <th width="35%">Address</th>
                        <th width="20%">Utilization</th>
                        <th width="10%">Type</th>
                        <th width="10%" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (lockers && lockers.length > 0) { %>
                        <% lockers.forEach(locker => { %>
                            <% 
                                let occupied = locker.compartments.filter(c => c.currentParcelId || c.isBooked).length;
                                let total = locker.compartments.length;
                                let percent = total > 0 ? (occupied / total) * 100 : 0;
                            %>
                            <tr>
                                <td>
                                    <div class="fw-bold"><%= locker.lockerId %></div>
                                    <div class="text-muted extra-small">SN: <%= locker._id.toString().slice(-6).toUpperCase() %></div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="status-dot status-online"></span>
                                        <span class="fw-medium small">Online</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="small fw-medium"><%= locker.location.address %></div>
                                    <div class="text-muted extra-small"><%= locker.location.pincode %></div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="mini-progress-container">
                                            <div class="progress">
                                                <div class="progress-bar" style="width: <%= percent %>%"></div>
                                            </div>
                                        </div>
                                        <span class="extra-small fw-bold text-dark"><%= occupied %>/<%= total %></span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted small">Standard</span>
                                </td>
                                <td class="text-end">
                                    <a href="/partner/my-lockers/<%= locker._id %>" class="btn-manage">
                                        Manage
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted small">
                                No lockers found in your fleet inventory.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>