<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Partner Dashboard | <%= partner.companyName || partner.partnerName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        :root {
            --brand-black: #111827;
            --brand-success: #10b981;
            --body-bg: #ffffff;
            --text-main: #111827;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --sidebar-width: 260px;
        }

        body { 
            background-color: var(--body-bg); 
            font-family: 'Inter', sans-serif; 
            color: var(--text-main);
            overflow-x: hidden;
            letter-spacing: -0.01em;
        }

        #main-wrapper {
            margin-left: var(--sidebar-width);
            padding: 40px 60px !important;
            min-height: 100vh;
        }

        /* Header Style */
        .page-header {
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 32px;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .icon-box-minimal {
            width: 54px;
            height: 54px;
            background: #f8fafc;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--brand-black);
            font-size: 1.25rem;
        }

        /* Revenue Metrics */
        .revenue-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            margin-bottom: 4px;
            display: block;
        }

        .revenue-amount {
            font-size: 3.5rem;
            font-weight: 800;
            letter-spacing: -0.05em;
            color: var(--brand-black);
            margin: 0;
        }

        .stat-card-minimal {
            padding: 20px;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            background: #ffffff;
            height: 100%;
        }

        /* Payout Strip */
        .payout-strip {
            background: #f8fafc;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px 32px;
            margin: 48px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Minimal Table */
        .table-container-minimal {
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
        }

        .table-minimal {
            width: 100%;
            margin-bottom: 0;
        }

        .table-minimal thead th {
            background: #f8fafc;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 700;
            padding: 14px 24px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
        }

        .table-minimal tbody td {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            vertical-align: middle;
        }

        /* Buttons */
        .btn-black {
            background: var(--brand-black);
            color: #ffffff;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.875rem;
            transition: opacity 0.2s;
        }

        .btn-black:hover {
            opacity: 0.9;
            color: #ffffff;
        }

        .btn-outline-minimal {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--brand-black);
            padding: 8px 16px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .btn-outline-minimal:hover {
            background: #f8fafc;
            border-color: var(--brand-black);
        }

        .status-pill {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 4px;
            border: 1px solid transparent;
        }

        .status-active { background: #f0fdf4; color: #166534; border-color: #bbf7d0; }

        @media (max-width: 992px) {
            #main-wrapper { margin-left: 0; padding: 40px 20px !important; }
            .payout-strip { flex-direction: column; gap: 20px; text-align: center; }
        }
    </style>
</head>
<body>

<%- include("./imports/topbar") %>
<%- include("./imports/sidebar") %>

<div id="main-wrapper">
    <div class="page-header mt-5">
        <div class="d-flex align-items-center gap-3">
            <div class="icon-box-minimal">
                <i class="fas fa-building"></i>
            </div>
            <div>
                <span class="revenue-label">Organization</span>
                <h3 class="fw-bold mb-0"><%= partner.partnerName %></h3>
                <div class="text-muted extra-small mt-1">
                    <i class="fas fa-map-marker-alt me-1"></i> <%= partner.city %>, <%= partner.state %>
                </div>
            </div>
        </div>
        <div>
            <span class="status-pill status-active"><%= partner.verificationStatus %></span>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-6">
            <span class="revenue-label">Total Partner Earnings</span>
            <h1 class="revenue-amount">₹<%= partner.revenueStats.totalPartnerEarned.toLocaleString('en-IN') %></h1>
            <p class="text-muted small mt-2">Aggregated revenue from <%= partner.lockers.length %> lockers</p>
        </div>
        <div class="col-lg-3">
            <div class="stat-card-minimal">
                <span class="revenue-label">Gross Volume</span>
                <div class="h4 fw-bold mb-0">₹<%= partner.revenueStats.totalGross.toLocaleString('en-IN') %></div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="stat-card-minimal">
                <span class="revenue-label">Revenue Share</span>
                <div class="h4 fw-bold mb-0"><%= partner.revenue.rules.partnerSharePercent %>%</div>
                <div class="extra-small text-muted mt-1">Partner Proportion</div>
            </div>
        </div>
    </div>

    <div class="payout-strip">
        <div class="d-flex align-items-center gap-4">
            <div class="icon-box-minimal" style="width: 44px; height: 44px; font-size: 1rem;">
                <i class="fas fa-wallet"></i>
            </div>
            <div>
                <span class="revenue-label" style="margin-bottom: 0;">Unsettled Balance</span>
                <div class="h5 fw-bold mb-0">₹<%= partner.revenueStats.pendingPayout.toLocaleString('en-IN') %></div>
            </div>
        </div>
        <button class="btn-black">Request Settlement <i class="fas fa-arrow-right ms-2 small"></i></button>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h5 class="fw-bold mb-0">Hardware Fleet</h5>
            <p class="text-muted small mb-0">Management of active deployment units</p>
        </div>
        <button class="btn-outline-minimal" data-bs-toggle="modal" data-bs-target="#deploymentModal">
            <i class="fas fa-plus me-2"></i>Request Deployment
        </button>
    </div>

    <div class="table-container-minimal">
        <table class="table-minimal">
            <thead>
                <tr>
                    <th>Locker ID</th>
                    <th>Location Details</th>
                    <th>Configuration</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% partner.lockers.forEach(locker => { %>
                    <tr>
                        <td class="fw-bold"><%= locker.lockerId || 'N/A' %></td>
                        <td>
                            <div class="fw-medium"><%= partner.city %></div>
                            <div class="extra-small text-muted"><%= partner.pincode %></div>
                        </td>
                        <td><span class="text-muted small">Standard Smart Locker</span></td>
                        <td><span class="status-pill status-active">Active</span></td>
                    </tr>
                <% }) %>
                <% if(partner.lockers.length === 0) { %>
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted small">No active units deployed.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>