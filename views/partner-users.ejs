<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Location Users | Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        :root {
            --brand-blue: #2563eb;
            --border-color: #e2e8f0;
            --sidebar-width: 240px;
            --excel-header: #f8fafc;
        }

        body {
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            color: #1e293b;
        }

        #main-wrapper {
            margin-left: var(--sidebar-width);
            padding: 20px 30px !important;
        }

        /* Summary Strip */
        .excel-summary-strip {
            display: flex;
            gap: 2rem;
            padding: 1rem 0;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 1.5rem;
            font-size: 0.85rem;
        }
        .summary-item b { font-weight: 700; font-size: 1rem; color: var(--brand-blue); }
        .summary-label { color: #64748b; font-weight: 500; }

        /* Search & Filter Bar */
        .config-bar-slim {
            background: #f1f5f9;
            border-radius: 8px;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .search-input-group {
            position: relative;
            width: 300px;
        }
        .search-input-group i {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.8rem;
        }
        .search-input-group input {
            padding-left: 32px;
            height: 32px;
            font-size: 0.85rem;
            border: 1px solid var(--border-color);
            border-radius: 6px;
        }

        /* Excel Table */
        .excel-container {
            border: 1px solid var(--border-color);
            border-radius: 4px;
            overflow: hidden;
        }
        .table-excel {
            width: 100%;
            margin-bottom: 0;
            font-size: 0.82rem;
            border-collapse: collapse;
        }
        .table-excel thead th {
            background: var(--excel-header);
            color: #64748b;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.7rem;
            padding: 10px 12px;
            border-bottom: 1px solid var(--border-color);
            border-right: 1px solid #f1f5f9;
        }
        .table-excel tbody td {
            padding: 10px 12px;
            border-bottom: 1px solid #f1f5f9;
            border-right: 1px solid #f8fafc;
            white-space: nowrap;
            vertical-align: middle;
        }
        .table-excel tbody tr:hover {
            background-color: #f0f7ff !important;
        }

        .user-icon-box {
            width: 28px;
            height: 28px;
            background: #eff6ff;
            color: var(--brand-blue);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 10px;
        }

        @media (max-width: 992px) {
            #main-wrapper { margin-left: 0; padding-top: 80px !important; }
        }
    </style>
</head>

<body>

    <%- include("./imports/topbar.ejs") %>
    <%- include("./imports/sidebar.ejs") %>

    <div id="main-wrapper">
        <div class="excel-summary-strip">
            <div class="summary-item">
                <span class="summary-label">Total Users:</span> 
                <b id="totalCount"><%= users.length %></b>
            </div>
            <div class="summary-item">
                <span class="summary-label">Database Status:</span> 
                <b class="text-success"><i class="fas fa-database me-1"></i>Connected</b>
            </div>
        </div>

        <div class="config-bar-slim">
            <div class="search-input-group">
                <i class="fas fa-search"></i>
                <input type="text" id="userSearch" class="form-control shadow-none" placeholder="Search by name or phone..." onkeyup="filterUsers()">
            </div>
            <div class="text-muted" style="font-size: 0.75rem;">
                Showing <b><%= users.length %></b> entries
            </div>
        </div>

        <div class="excel-container">
            <div class="table-responsive">
                <table class="table-excel" id="userTable">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th>Username</th>
                            <th>Phone Number</th>
                            <th>Email Address</th>
                            <th>Registration Date</th>
                            <th class="text-center">Profile</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-users-slash d-block mb-2" style="font-size: 1.5rem;"></i>
                                    No users found for this location partner.
                                </td>
                            </tr>
                        <% } %>

                        <% users.forEach((user, index) => { %>
                        <tr>
                            <td class="text-muted"><%= index + 1 %></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="user-icon-box">
                                        <i class="fas fa-user-circle"></i>
                                    </div>
                                    <span class="fw-semibold text-dark"><%= user.username %></span>
                                </div>
                            </td>
                            <td>
                                <code class="text-primary fw-medium" style="background: transparent;"><%= user.phone || "---" %></code>
                            </td>
                            <td>
                                <span class="text-muted"><%= user.email || "No Email Provided" %></span>
                            </td>
                            <td>
                                <span class="text-secondary">
                                    <%= new Date(user.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </span>
                            </td>
                            <td class="text-center">
                                <i class="fas fa-arrow-right text-light-emphasis" style="font-size: 0.7rem;"></i>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Simple search filter functionality
        function filterUsers() {
            const input = document.getElementById("userSearch");
            const filter = input.value.toLowerCase();
            const table = document.getElementById("userTable");
            const tr = table.getElementsByTagName("tr");

            for (let i = 1; i < tr.length; i++) {
                const nameCol = tr[i].getElementsByTagName("td")[1];
                const phoneCol = tr[i].getElementsByTagName("td")[2];
                
                if (nameCol || phoneCol) {
                    const txtValue = (nameCol.textContent || nameCol.innerText) + " " + 
                                   (phoneCol.textContent || phoneCol.innerText);
                    if (txtValue.toLowerCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }
    </script>
</body>

</html>