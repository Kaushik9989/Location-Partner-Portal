<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Partners | Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        :root {
            --brand-blue: #2563eb;
            --border-color: #e2e8f0;
            --sidebar-width: 240px;
            --excel-header: #f8fafc;
        }

        body {
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            color: #1e293b;
        }

        #main-wrapper {
            margin-left: var(--sidebar-width);
            padding: 20px 30px !important;
        }

        /* High Density Excel Header Section */
        .excel-summary-strip {
            display: flex;
            gap: 2rem;
            padding: 1rem 0;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 1.5rem;
            font-size: 0.85rem;
        }

        .summary-item b { font-weight: 700; font-size: 1rem; color: var(--brand-blue); }
        .summary-label { color: #64748b; font-weight: 500; }

        /* Configuration Bar - Slimmer */
        .config-bar-slim {
            background: #f1f5f9;
            border-radius: 8px;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }

        /* The "Excel" Table */
        .excel-container {
            border: 1px solid var(--border-color);
            border-radius: 4px;
            overflow: hidden;
        }

        .table-excel {
            width: 100%;
            margin-bottom: 0;
            font-size: 0.82rem; /* Smaller font for more data */
            border-collapse: collapse;
        }

        .table-excel thead th {
            background: var(--excel-header);
            color: #64748b;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.03em;
            padding: 10px 12px;
            border-bottom: 1px solid var(--border-color);
            border-right: 1px solid #f1f5f9;
        }

        .table-excel tbody td {
            padding: 8px 12px;
            border-bottom: 1px solid #f1f5f9;
            border-right: 1px solid #f8fafc;
            white-space: nowrap;
        }

        .table-excel tbody tr:hover {
            background-color: #f0f7ff !important;
            cursor: pointer;
        }

        /* Components */
        .partner-mini-avatar {
            width: 24px;
            height: 24px;
            border-radius: 4px;
            object-fit: cover;
            margin-right: 8px;
        }

        .company-tag {
            background: #e2e8f0;
            color: #475569;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .status-dot-sm {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }

        /* Modal & UI State */
        .modal-content { border-radius: 12px; }
        .btn-loading { pointer-events: none; opacity: 0.7; }

        @media (max-width: 992px) {
            #main-wrapper { margin-left: 0; padding-top: 80px !important; }
        }
    </style>
</head>

<body>

    <%- include("./imports/topbar.ejs") %>
    <%- include("./imports/sidebar.ejs") %>

    <div id="main-wrapper">
        <div class="excel-summary-strip">
            <div class="summary-item">
                <span class="summary-label">Total Agents:</span> <b><%= partners.length %></b>
            </div>
            <div class="summary-item">
                <span class="summary-label">Checked-In:</span> <b class="text-success"><%= partners.filter(p => p.isCheckedIn).length %></b>
            </div>
            <div class="summary-item">
                <span class="summary-label">Registration Rate:</span> <b>+12%</b>
            </div>
        </div>

        <div class="config-bar-slim">
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-cog text-muted"></i>
                <span class="fw-bold">Default Max Stay:</span>
                <input type="number" id="stayDurationInput" class="form-control form-control-sm text-center fw-bold" 
                       style="width: 70px; height: 28px;" value="<%= partner.stayDuration %>">
                <span class="text-muted">minutes</span>
                <button class="btn btn-primary btn-sm py-0" id="updateBtn" onclick="updateStayDuration()" style="height: 28px;">
                    Apply
                </button>
            </div>
            <div class="text-muted extra-small">
                Last updated: Just now
            </div>
        </div>

        <div class="excel-container">
            <div class="table-responsive">
                <table class="table-excel">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Partner Name</th>
                            <th>Contact Number</th>
                            <th>Companies</th>
                            <th>Internal Status</th>
                            <th>Live Status</th>
                            <th>Onboarding Date</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% partners.forEach(function(p, index){ %>
                        <tr onclick="showPartnerDetails(<%= JSON.stringify(p) %>)">
                            <td class="text-muted"><%= index + 1 %></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    
                                        <div class="partner-mini-avatar bg-light d-flex align-items-center justify-content-center">
                                            <i class="fas fa-user text-muted" style="font-size: 0.6rem;"></i>
                                        </div>
                                    
                                    <span class="fw-bold"><%= p.name %></span>
                                </div>
                            </td>
                            <td><code class="text-primary" style="font-size: 0.8rem;"><%= p.phone %></code></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <% p.deliveryCompanies.slice(0, 2).forEach(function(company) { %>
                                        <span class="company-tag"><%= company %></span>
                                    <% }) %>
                                    <% if(p.deliveryCompanies.length > 2) { %>
                                        <span class="company-tag">+<%= p.deliveryCompanies.length - 2 %></span>
                                    <% } %>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-1 fw-bold <%= p.status==='active' ? 'bg-success-subtle text-success' : 'bg-warning-subtle text-warning' %>" style="font-size: 0.65rem;">
                                    <%= p.status.toUpperCase() %>
                                </span>
                            </td>
                            <td>
                                <% if(p.isCheckedIn){ %>
                                    <span class="status-dot-sm bg-success"></span><span class="text-success fw-medium">Active</span>
                                <% } else { %>
                                    <span class="status-dot-sm bg-secondary"></span><span class="text-muted">Inactive</span>
                                <% } %>
                            </td>
                            <td><%= new Date(p.createdAt).toLocaleDateString('en-GB') %></td>
                            <td class="text-center">
                                <i class="fas fa-external-link-alt text-muted" style="font-size: 0.7rem;"></i>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        async function updateStayDuration() {
            const btn = document.getElementById("updateBtn");
            const originalContent = btn.innerHTML;
            btn.classList.add('btn-loading');
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';

            try {
                const stayDuration = document.getElementById("stayDurationInput").value;
                const res = await fetch("/admin/location-partner/stay-duration", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        locationPartnerId: "<%= partner._id %>",
                        stayDuration
                    })
                });
                const data = await res.json();
                if (data.success) {
                    btn.className = "btn btn-success btn-sm py-0";
                    btn.innerHTML = 'Done';
                    setTimeout(() => {
                        btn.className = "btn btn-primary btn-sm py-0";
                        btn.innerHTML = originalContent;
                    }, 2000);
                }
            } catch (error) {
                console.error(error);
                btn.innerHTML = originalContent;
            } finally {
                btn.classList.remove('btn-loading');
            }
        }

        function showPartnerDetails(partner) {
            document.getElementById('modalName').innerText = partner.name;
            document.getElementById('modalPhone').innerText = partner.phone;
            const date = new Date(partner.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
            document.getElementById('modalDate').innerText = date;
            const photoContainer = document.getElementById('modalPhotoContainer');
            photoContainer.innerHTML = partner.photo ? `<img src="${partner.photo}" class="modal-photo-detailed">` : `<div class="avatar-placeholder mx-auto" style="width:120px; height:120px; font-size: 3rem; border-radius: 24px;"><i class="fas fa-user-tie"></i></div>`;
            const statusContainer = document.getElementById('modalStatusBadge');
            const isActive = partner.status === 'active';
            statusContainer.innerHTML = `<span class="badge ${isActive ? 'bg-success-subtle text-success' : 'bg-warning-subtle text-warning'} border px-3 py-2 rounded-pill">${partner.status.toUpperCase()}</span>`;
            const companyContainer = document.getElementById('modalCompanies');
            companyContainer.innerHTML = '';
            partner.deliveryCompanies.forEach(company => {
                const span = document.createElement('span');
                span.className = 'company-pill m-0';
                span.innerText = company;
                companyContainer.appendChild(span);
            });
            new bootstrap.Modal(document.getElementById('partnerModal')).show();
        }
    </script>

            <div class="modal fade" id="partnerModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">Partner Profile</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="text-center mb-4">
                                <div id="modalPhotoContainer">
                                </div>
                                <h3 class="fw-bold mt-3 mb-1" id="modalName"></h3>
                                <div id="modalStatusBadge"></div>
                            </div>

                            <div class="row g-4 mt-2">
                                <div class="col-6">
                                    <div class="info-label">Phone Number</div>
                                    <div class="info-value" id="modalPhone"></div>
                                </div>
                                <div class="col-6">
                                    <div class="info-label">Registration Date</div>
                                    <div class="info-value" id="modalDate"></div>
                                </div>
                                <div class="col-12">
                                    <div class="info-label">Assigned Companies</div>
                                    <div id="modalCompanies" class="d-flex flex-wrap gap-2 mt-1"></div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0 pb-4 justify-content-center">
                            <button type="button" class="btn btn-light px-4 fw-bold rounded-3"
                                data-bs-dismiss="modal">Close Profile</button>
                        </div>
                    </div>
                </div>
            </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>