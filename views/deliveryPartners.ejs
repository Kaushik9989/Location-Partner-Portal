<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Partners | Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

        :root {
            --brand-blue: #2563eb;
            --brand-success: #10b981;
            --panel-bg: #ffffff;
            --body-bg: #f8fafc;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --sidebar-width: 280px;
            --topbar-height: 72px;
        }

        body {
            background-color: var(--body-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-main);
        }

        #main-wrapper {
            margin-left: var(--sidebar-width);
            padding: calc(var(--topbar-height) + 32px) 40px 40px 40px !important;
            min-height: 100vh;
        }

        /* Header Card Style */
        .page-header-card {
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 32px;
            margin-bottom: 32px;
            box-shadow: 0 4px 20px -10px rgba(0, 0, 0, 0.05);
        }

        .icon-box-metro {
            background: linear-gradient(135deg, var(--brand-blue), #1d4ed8);
            color: white;
            border-radius: 18px;
            width: 56px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.25);
        }

        /* Table Styling */
        .content-card {
            background: white;
            border-radius: 24px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .table thead th {
            background-color: #f8fafc;
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            padding: 16px 24px;
            border-bottom: 1px solid var(--border-color);
        }

        .table tbody td {
            padding: 18px 24px;
            border-bottom: 1px solid #f1f5f9;
        }

        /* Partner Specific Styles */
        .partner-avatar {
            width: 48px;
            height: 48px;
            object-fit: cover;
            border-radius: 14px;
            border: 2px solid #f1f5f9;
        }

        .avatar-placeholder {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: 1.2rem;
        }

        .company-pill {
            background: #f1f5f9;
            color: #475569;
            font-size: 0.75rem;
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 8px;
            margin-right: 4px;
        }

        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .dot {
            height: 8px;
            width: 8px;
            border-radius: 50%;
        }

        @media (max-width: 992px) {
            #main-wrapper {
                margin-left: 0;
                padding: 100px 20px 20px 20px !important;
            }
        }
        /* New Config Card Styling */
.config-card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 20px 24px;
    transition: all 0.3s ease;
}

.config-icon {
    width: 40px;
    height: 40px;
    background: #eff6ff;
    color: var(--brand-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    font-size: 1.1rem;
}

#stayDurationInput:focus {
    box-shadow: none;
    outline: none;
}

/* Button Loading State */
.btn-loading {
    pointer-events: none;
    opacity: 0.7;
}

.btn-loading i {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Clickable Rows */
tbody tr {
    cursor: pointer;
    transition: background-color 0.2s ease;
}
tbody tr:hover {
    background-color: #f8fafc;
}

/* Modal Styling */
.modal-content {
    border-radius: 28px;
    border: none;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
}

.modal-header {
    border-bottom: 1px solid #f1f5f9;
    padding: 24px 32px;
}

.modal-body {
    padding: 32px;
}

.modal-photo-detailed {
    width: 120px;
    height: 120px;
    border-radius: 24px;
    object-fit: cover;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    border: 4px solid white;
}

.info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 4px;
}

.info-value {
    font-weight: 600;
    color: var(--text-main);
    font-size: 1rem;
}
    </style>
</head>

<body>

    <%- include("./imports/topbar.ejs") %>
        <%- include("./imports/sidebar.ejs") %>

            <div id="main-wrapper">
                <div class="page-header-card d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-4">
                        <div class="icon-box-metro">
                            <i class="fas fa-truck-fast fa-lg"></i>
                        </div>
                        <div>
                            <span class="text-muted small fw-bold text-uppercase">Personnel Management</span>
                            <h2 class="fw-bold mb-0">Delivery Partners</h2>
                            <p class="text-muted small mb-0 mt-1">
                                Manage and monitor <%= partners.length %> active field agents
                            </p>
                        </div>
                    </div>

                </div>
               <div class="config-card mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="config-icon">
                <i class="fas fa-clock"></i>
            </div>
            <div>
                <h6 class="fw-bold mb-0">Delivery Stay Duration</h6>
                <p class="text-muted small mb-0">Set the maximum allowed time for field agent visits</p>
            </div>
        </div>
        
        <div class="d-flex align-items-center gap-2 bg-light p-2 rounded-4 border">
            <div class="input-group input-group-sm" style="width: 160px;">
                <input type="number" 
                       id="stayDurationInput" 
                       class="form-control border-0 bg-transparent fw-bold text-center" 
                       value="<%= partner.stayDuration %>"
                       placeholder="0">
                <span class="input-group-text border-0 bg-transparent text-muted small">mins</span>
            </div>
            <button class="btn btn-primary btn-sm px-4 rounded-3 fw-semibold shadow-sm" 
                    id="updateBtn"
                    onclick="updateStayDuration()">
                <i class="fas fa-sync-alt me-2"></i>Update
            </button>
        </div>
    </div>
</div>
                <div class="content-card">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Partner Details</th>
                                    <th>Contact Info</th>
                                    <th>Assigned Companies</th>
                                    <th>Operational Status</th>
                                    <th>Check-In</th>
                                    <th class="text-end pe-4">Registration</th>
                                </tr>
                            </thead>
                            <tbody>
                            <% partners.forEach(function(p){ %>
    <tr onclick="showPartnerDetails(<%= JSON.stringify(p) %>)">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <% if(p.photo){ %>
                                                    <img src="<%= p.photo %>" class="partner-avatar me-3">
                                                    <% } else { %>
                                                        <div class="avatar-placeholder me-3">
                                                            <i class="fas fa-user-tie"></i>
                                                        </div>
                                                        <% } %>
                                                            <div>
                                                                <div class="fw-bold text-dark">
                                                                    <%= p.name %>
                                                                </div>

                                                            </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-medium small">
                                                <%= p.phone %>
                                            </div>
                                            <div class="text-muted extra-small">Verified Phone</div>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-1">
                                                <% p.deliveryCompanies.forEach(function(company) { %>
                                                    <span class="company-pill">
                                                        <%= company %>
                                                    </span>
                                                    <% }) %>
                                            </div>
                                        </td>
                                        <td>
                                            <% if(p.status==='active' ) { %>
                                                <span
                                                    class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">Active</span>
                                                <% } else { %>
                                                    <span
                                                        class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill">
                                                        <%= p.status %>
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <% if(p.isCheckedIn){ %>
                                                <div class="status-indicator text-success">
                                                    <span class="dot bg-success"></span> Online
                                                </div>
                                                <% } else { %>
                                                    <div class="status-indicator text-muted">
                                                        <span class="dot bg-secondary"></span> Offline
                                                    </div>
                                                    <% } %>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="small fw-medium">
                                                <%= new Date(p.createdAt).toLocaleDateString('en-GB') %>
                                            </div>
                                            <div class="text-muted extra-small">
                                                <%= new Date(p.createdAt).toLocaleTimeString([], {hour: '2-digit' ,
                                                    minute:'2-digit'}) %>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <script>
async function updateStayDuration() {
    const btn = document.getElementById("updateBtn");
    const originalContent = btn.innerHTML;
    
    // UI Feedback: Loading
    btn.classList.add('btn-loading');
    btn.innerHTML = '<i class="fas fa-circle-notch fa-spin me-2"></i>Saving...';

    try {
        const stayDuration = document.getElementById("stayDurationInput").value;
        const res = await fetch("/admin/location-partner/stay-duration", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                locationPartnerId: "<%= partner._id %>",
                stayDuration
            })
        });

        const data = await res.json();

        if (data.success) {
            // Optional: Success animation/toast
            btn.className = "btn btn-success btn-sm px-4 rounded-3 fw-semibold";
            btn.innerHTML = '<i class="fas fa-check me-2"></i>Saved';
            
            setTimeout(() => {
                btn.className = "btn btn-primary btn-sm px-4 rounded-3 fw-semibold shadow-sm";
                btn.innerHTML = originalContent;
            }, 2000);
        } else {
            alert("Update failed: " + (data.message || "Unknown error"));
            btn.innerHTML = originalContent;
            btn.classList.remove('btn-loading');
        }
    } catch (error) {
        console.error(error);
        alert("Network error occurred");
        btn.innerHTML = originalContent;
        btn.classList.remove('btn-loading');
    }
}
function showPartnerDetails(partner) {
    // 1. Set Name and Phone
    document.getElementById('modalName').innerText = partner.name;
    document.getElementById('modalPhone').innerText = partner.phone;
    
    // 2. Set Date
    const date = new Date(partner.createdAt).toLocaleDateString('en-GB', {
        day: 'numeric', month: 'long', year: 'numeric'
    });
    document.getElementById('modalDate').innerText = date;

    // 3. Set Photo
    const photoContainer = document.getElementById('modalPhotoContainer');
    if(partner.photo) {
        photoContainer.innerHTML = `<img src="${partner.photo}" class="modal-photo-detailed">`;
    } else {
        photoContainer.innerHTML = `
            <div class="avatar-placeholder mx-auto" style="width:120px; height:120px; font-size: 3rem; border-radius: 24px;">
                <i class="fas fa-user-tie"></i>
            </div>`;
    }

    // 4. Set Status Badge
    const statusContainer = document.getElementById('modalStatusBadge');
    const isActive = partner.status === 'active';
    statusContainer.innerHTML = `
        <span class="badge ${isActive ? 'bg-success-subtle text-success border-success-subtle' : 'bg-warning-subtle text-warning border-warning-subtle'} border px-3 py-2 rounded-pill">
            ${partner.status.toUpperCase()}
        </span>`;

    // 5. Set Companies
    const companyContainer = document.getElementById('modalCompanies');
    companyContainer.innerHTML = ''; // Clear previous
    partner.deliveryCompanies.forEach(company => {
        const span = document.createElement('span');
        span.className = 'company-pill m-0';
        span.style.fontSize = '0.85rem';
        span.innerText = company;
        companyContainer.appendChild(span);
    });

    // 6. Show Modal
    const myModal = new bootstrap.Modal(document.getElementById('partnerModal'));
    myModal.show();
}
            </script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            
            <div class="modal fade" id="partnerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Partner Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <div id="modalPhotoContainer">
                        </div>
                    <h3 class="fw-bold mt-3 mb-1" id="modalName"></h3>
                    <div id="modalStatusBadge"></div>
                </div>

                <div class="row g-4 mt-2">
                    <div class="col-6">
                        <div class="info-label">Phone Number</div>
                        <div class="info-value" id="modalPhone"></div>
                    </div>
                    <div class="col-6">
                        <div class="info-label">Registration Date</div>
                        <div class="info-value" id="modalDate"></div>
                    </div>
                    <div class="col-12">
                        <div class="info-label">Assigned Companies</div>
                        <div id="modalCompanies" class="d-flex flex-wrap gap-2 mt-1"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pb-4 justify-content-center">
                <button type="button" class="btn btn-light px-4 fw-bold rounded-3" data-bs-dismiss="modal">Close Profile</button>
            </div>
        </div>
    </div>
</div>
</body>

</html>